# ════════════════════════════════════════════════════════════════
# Credenciales ARCA — POC standalone
# ════════════════════════════════════════════════════════════════
# Copiar este archivo como `.env` y completar.
# El `.env` real NUNCA debe subirse a git (está en .gitignore).

# CUIT y clave fiscal del usuario que loguea (vos)
ARCA_CUIT_PERSONAL=20XXXXXXXXX
ARCA_PASSWORD_PERSONAL=tu_clave_fiscal

# CUIT del representado (empresa cuyos comprobantes querés bajar)
# Se elige en el dropdown del portal de Mis Comprobantes
ARCA_CUIT_EMPRESA_MSA=30617786016
ARCA_CUIT_EMPRESA_PAM=30000000000

# Si MA usa OTRO CUIT que loguea (otra persona o tu mismo con otra clave)
ARCA_CUIT_PERSONAL_MA=20XXXXXXXXX
ARCA_PASSWORD_PERSONAL_MA=otra_clave_fiscal
ARCA_CUIT_EMPRESA_MA=30000000000

# Parámetros de la consulta de prueba (formato YYYY-MM-DD)
ARCA_FECHA_DESDE=2026-05-01
ARCA_FECHA_HASTA=2026-05-31
ARCA_TIPO=recibidos   # recibidos | emitidos
ARCA_EMPRESA=MSA      # MSA | PAM | MA
